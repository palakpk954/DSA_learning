CODE 2: PASS BY VALUE AND PASS BY REFRENCE USING SOME CHANGE FUNCTION WHICH WE CREATED

#include <iostream>
using namespace std;
class Student{//student is a new datatype
public:
string name;
int rno;
float gpa;
};

void print (Student s){
    cout<<s.name<<" "<<s.rno<<" "<<s.gpa<<" "<<endl;
}

void change(Student& s){ //&ki wajah se pass by refrence ho gya
    s.name="khushi";
    
}

int main(){
    Student s1;
    s1.name = "palak";
    s1.rno = 89;
    s1.gpa = 9.8;
    
    Student s2;
    s2.name = "ram";
    s2.rno = 9;
    s2.gpa = 9.2;
    
    
    print(s1);
    change(s1); //pass by value tha when & was not used
    print(s1);
    //print(s2);
    


    return 0;
}

CODE 3: COPY CONSTRACTOR AND DEEP COPY

#include <iostream>
using namespace std;
class Student{//student is a new datatype
public:
string name;
int rno;
float gpa;
Student(){//default constructor
    
}
Student(string s, int r, float g){ //parameterised constructor
    name = s;
    rno = r;
    gpa = g;}
};

void print (Student s){
    cout<<s.name<<" "<<s.rno<<" "<<s.gpa<<" "<<endl;
}

void change(Student& s){ //&ki wajah se pass by refrence ho gya
    s.name="khushi";
    
}

int main(){
    Student s1;
    s1.name = "palak";
    s1.rno = 89;
    s1.gpa = 9.8;
    
    Student s2;
    s2.name = "ram";
    s2.rno = 9;
    s2.gpa = 9.2;
    
    Student s3=s1;//deep copy
    s3.name="radha";
    
    Student s4(s2);//copy constructor--deep copy(cpp specific)
    
    print(s1);
    change(s1); //pass by value tha when & was not used
    print(s1);
    print(s2);
    print(s3);
    print(s4);


    return 0;
}

